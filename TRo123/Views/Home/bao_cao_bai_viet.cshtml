@{
    ViewData["Title"] = "Báo cáo bài viết";
    var postId = ViewData["PostId"] ?? 1;
}

<div class="member-layout">
    @await Html.PartialAsync("_thanh_vien_sidebar")
    <section class="member-content">
        <div class="form-page full-width">
            <h1>Báo cáo bài viết</h1>
            <p>Hãy cho chúng tôi biết bằng cách điền thông tin dưới đây.</p>

            <form class="post-form report-form mt-4">
                <div class="row mb-3">
                    <div class="col-md-7">
                        <label class="form-label">Họ tên người báo cáo</label>
                        <input class="form-control" />
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-7">
                        <label class="form-label">Giới tính</label>
                        <input class="form-control" />
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-7">
                        <label class="form-label">Địa chỉ</label>
                        <input class="form-control" />
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-7">
                        <label class="form-label">Số điện thoại liên hệ</label>
                        <input class="form-control" />
                    </div>
                </div>
                <div class="row mb-4">
                    <div class="col-md-9">
                        <label class="form-label">Đường link bài viết bạn cho là vi phạm</label>
                        <input class="form-control" value="https://localhost:5001/Home/Detail/@postId" />
                    </div>
                </div>

                <h4>Bài viết đã vi phạm tiêu chuẩn cộng đồng nào?</h4>
                <div class="violation-list">
                    <label><input type="radio" name="violation" /> Giả mạo người khác</label>
                    <label><input type="radio" name="violation" /> Spam hoặc gây hại</label>
                    <label><input type="radio" name="violation" /> Không dùng tên thật</label>
                    <label><input type="radio" name="violation" /> Đăng nội dung không phù hợp</label>
                    <label><input type="radio" name="violation" /> Lừa đảo</label>
                    <label><input type="radio" name="violation" /> Vấn đề khác</label>
                </div>

                <div class="d-flex gap-3 mt-4">
                    <button type="button" class="btn btn-outline-primary px-4">Hủy</button>
                    <button type="button" class="btn btn-primary px-4">Gửi</button>
                </div>
            </form>
        </div>
    </section>
</div>
