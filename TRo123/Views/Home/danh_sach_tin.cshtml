@model List<TRo123.Models.PhongTroItemViewModel>
@{
    ViewData["Title"] = "Danh sách tin";
    var boLoc = ViewData["BoLoc"] as TRo123.Models.TimKiemPhongViewModel ?? new();
    var tinhThanhPho = ViewData["TinhThanhPho"] as List<TRo123.Models.TinhThanhPhoDto> ?? [];
    var quanHuyen = ViewData["QuanHuyen"] as List<TRo123.Models.QuanHuyenDto> ?? [];
}

<div class="page-heading">
    <h1>Cho thuê phòng trọ</h1>
    <p>Tổng hợp tin đăng mới nhất, đã được kiểm duyệt thông tin cơ bản.</p>
</div>

<form class="filter-bar" asp-controller="Home" asp-action="Listings" method="get">
    <input type="text" name="tuKhoa" value="@boLoc.TuKhoa" placeholder="Từ khóa" />
    <select name="maTinhThanhPho" id="selTinh">
        <option value="">Tỉnh/Thành phố</option>
        @foreach (var item in tinhThanhPho)
        {
            <option value="@item.MaTinhThanhPho" selected="@(boLoc.MaTinhThanhPho == item.MaTinhThanhPho ? "selected" : null)">@item.TenTinhThanhPho</option>
        }
    </select>
    <select name="maQuanHuyen" id="selQuan">
        <option value="">Quận/Huyện</option>
        @foreach (var item in quanHuyen)
        {
            <option value="@item.MaQuanHuyen" selected="@(boLoc.MaQuanHuyen == item.MaQuanHuyen ? "selected" : null)">@item.TenQuanHuyen</option>
        }
    </select>
    <input type="number" min="0" name="giaMin" value="@boLoc.GiaMin" placeholder="Giá từ" />
    <input type="number" min="0" name="giaMax" value="@boLoc.GiaMax" placeholder="Giá đến" />
    <input type="number" min="0" name="dienTichMin" value="@boLoc.DienTichMin" placeholder="DT từ" />
    <input type="number" min="0" name="dienTichMax" value="@boLoc.DienTichMax" placeholder="DT đến" />
    <button type="submit" class="btn btn-danger">Lọc tin</button>
</form>

<div class="content-grid mt-3">
    <div class="left-col">
        @if (Model.Count == 0)
        {
            <div class="side-card">
                <p>Chưa có dữ liệu phòng trong SQL Server.</p>
            </div>
        }
        @foreach (var item in Model)
        {
            <article class="post-card">
                <img src="@(string.IsNullOrWhiteSpace(item.DuongDanAnh) ? "https://picsum.photos/seed/list-default/220/150" : item.DuongDanAnh)" alt="tin @item.MaPhong" />
                <div>
                    <h3><a asp-controller="Home" asp-action="Detail" asp-route-id="@item.MaPhong">@item.TenPhong - mã #@item.MaPhong</a></h3>
                    <div class="post-meta">
                        <span class="price">@item.GiaPhong.ToString("N0") đ/tháng</span>
                        <span>@item.DienTich m2</span>
                        <span>@item.DiaChiDayDu</span>
                    </div>
                    <p>Liên hệ: @item.SoDienThoai</p>
                </div>
            </article>
        }
    </div>
    <aside class="right-col">
        <div class="side-card">
            <h4>Xem theo khoảng giá</h4>
            <ul>
                <li><a asp-action="Listings" asp-route-giaMax="2000000">Dưới 2 triệu</a></li>
                <li><a asp-action="Listings" asp-route-giaMin="2000000" asp-route-giaMax="3000000">2 - 3 triệu</a></li>
                <li><a asp-action="Listings" asp-route-giaMin="3000000" asp-route-giaMax="5000000">3 - 5 triệu</a></li>
                <li><a asp-action="Listings" asp-route-giaMin="5000000">Trên 5 triệu</a></li>
            </ul>
        </div>
    </aside>
</div>

@section Scripts {
    <script>
        async function fetchJson(url) {
            const res = await fetch(url, { headers: { 'Accept': 'application/json' } });
            if (!res.ok) return [];
            return await res.json();
        }

        function fillSelect(sel, items, valueKey, textKey, placeholder) {
            const current = sel.value;
            sel.innerHTML = '';
            const opt0 = document.createElement('option');
            opt0.value = '';
            opt0.textContent = placeholder;
            sel.appendChild(opt0);
            for (const it of items) {
                const opt = document.createElement('option');
                opt.value = it[valueKey];
                opt.textContent = it[textKey];
                sel.appendChild(opt);
            }
            if (current) sel.value = current;
        }

        const selTinh = document.getElementById('selTinh');
        const selQuan = document.getElementById('selQuan');
        selTinh?.addEventListener('change', async () => {
            const maTinh = selTinh.value;
            const dsQuan = maTinh ? await fetchJson(`@Url.Action("QuanHuyen","Home")?maTinh=${encodeURIComponent(maTinh)}`) : [];
            fillSelect(selQuan, dsQuan, 'maQuanHuyen', 'tenQuanHuyen', 'Quận/Huyện');
        });
    </script>
}
