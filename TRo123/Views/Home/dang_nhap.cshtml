@model TRo123.Models.DangNhapViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="auth-page">
    <h1>Đăng nhập tài khoản</h1>
    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success">@successMessage</div>
    }
    <form class="auth-form" asp-action="Login" asp-controller="Home" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
        <label class="form-label">Email hoặc số điện thoại</label>
        <input class="form-control mb-1" asp-for="SoDienThoai" placeholder="Nhập số điện thoại" />
        <span asp-validation-for="SoDienThoai" class="text-danger small"></span>
        <label class="form-label">Mật khẩu</label>
        <input type="password" class="form-control mb-1" asp-for="MatKhau" placeholder="Nhập mật khẩu" />
        <span asp-validation-for="MatKhau" class="text-danger small"></span>
        <button type="submit" class="btn btn-danger w-100 mt-3">Đăng nhập</button>
        <p class="mt-3 mb-0">Chưa có tài khoản? <a asp-controller="Home" asp-action="Register">Đăng ký ngay</a></p>
    </form>
</div>
