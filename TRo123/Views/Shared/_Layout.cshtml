<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LaLaHome</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TRo123.styles.css" asp-append-version="true" />
</head>
<body class="site-body">
    <header class="site-header">
        <div class="container site-topbar">
            <a class="site-logo" asp-controller="Home" asp-action="Index">
                <span class="site-logo-main">LaLaHome</span>
                <span class="site-logo-sub">Hệ thống ngân hàng nhà trọ LaLaHome</span>
            </a>
            <div class="site-top-actions">
                @{
                    var maTaiKhoan = Context.Session.GetString("MaTaiKhoan");
                }
                @if (string.IsNullOrWhiteSpace(maTaiKhoan))
                {
                    <a class="site-link" asp-controller="Home" asp-action="Login">Đăng nhập</a>
                    <a class="site-link" asp-controller="Home" asp-action="Register">Đăng ký</a>
                }
                else
                {
                    <a class="site-link" asp-controller="Home" asp-action="Profile">Tài khoản</a>
                    <a class="site-link" asp-controller="Home" asp-action="Logout">Đăng xuất</a>
                }
                @{
                    var vaiTro = Context.Session.GetString("VaiTro");
                }
                @if (string.Equals(vaiTro, "ChuTro", StringComparison.OrdinalIgnoreCase))
                {
                    <a class="btn btn-warning btn-sm fw-semibold" asp-controller="Home" asp-action="CreatePost">Đăng tin mới</a>
                }
            </div>
        </div>
        <nav class="site-nav">
            <div class="container">
                <ul>
                    <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li><a asp-controller="Home" asp-action="Listings">Cho thuê phòng trọ</a></li>
                    <li><a asp-controller="Home" asp-action="Listings">Nhà cho thuê</a></li>
                    <li><a asp-controller="Home" asp-action="Listings">Căn hộ cho thuê</a></li>
                    <li><a asp-controller="Home" asp-action="Listings">Tìm người ở ghép</a></li>
                </ul>
            </div>
        </nav>
    </header>

    <main class="container py-4">
        <partial name="_Alerts" />
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container footer-grid">
            <div>
                <h5>Hệ thống ngân hàng nhà trọ LaLaHome</h5>
                <p>Nền tảng kết nối người tìm phòng và chủ trọ, hỗ trợ kiểm duyệt và quản lý thông tin minh bạch.</p>
            </div>
            <div>
                <h6>Liên kết nhanh</h6>
                <ul class="footer-links">
                    <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li><a asp-controller="Home" asp-action="Listings">Danh sách phòng trọ</a></li>
                    <li><a asp-controller="Home" asp-action="Privacy">Chính sách bảo mật</a></li>
                </ul>
            </div>
            <div>
                <h6>Hỗ trợ</h6>
                <ul class="footer-links">
                    <li>Email: support@lalahome.vn</li>
                    <li>Hotline: 1900 1234</li>
                    <li>Giờ làm việc: 08:00 - 22:00</li>
                </ul>
            </div>
        </div>
        <div class="container footer-bottom">
            <span>&copy; 2026 LaLaHome. All rights reserved.</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
